{
  "schemaVersion": 1,
  "id": "adamantite",
  "version": "${version}",
  "name": "Adamantite",
  "description": "Adamantite and Titanium. Ore generates after defeating the Ender Dragon.",
  "authors": [
    "wdfeer"
  ],
  "contact": {
    "sources": "https://github.com/wdfeer/adamantite"
  },
  "license": "GPL-3.0",
  "icon": "assets/adamantite/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "value": "wdfeer.adamantite.Adamantite",
        "adapter": "kotlin"
      }
    ],
    "client": [
      {
        "value": "wdfeer.adamantite.client.AdamantiteClient",
        "adapter": "kotlin"
      }
    ],
    "fabric-datagen": [
      {
        "value": "wdfeer.adamantite.datagen.AdamantiteDataGenerator",
        "adapter": "kotlin"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.1",
    "java": "*",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  },
  "recommends": {
    "ranged-weapon-api": "*"
  }
}